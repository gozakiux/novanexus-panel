# Plantilla de variables de entorno. Copia este archivo como `.env.local`
# y completa los valores reales. `.env.local` esta gitignored (no se sube).

# URL del proyecto Supabase
SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Claves de cliente (publicas, seguras en el navegador, protegidas por RLS)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
VITE_SUPABASE_ANON_KEY=eyJhbG...   # JWT anon

# Claves SECRETAS (solo scripts locales/servidor — NUNCA con prefijo VITE_)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...   # JWT service_role

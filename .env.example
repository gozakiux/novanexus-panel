# Variables PÚBLICAS del frontend. Copia este archivo como `.env.local`.
# La clave publishable/anon es pública por diseño (va en el bundle del cliente);
# la seguridad real es RLS + login en Supabase.
# Las claves SECRETAS NO van aquí — ver `.env.server.example`.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
VITE_SUPABASE_ANON_KEY=eyJhbG...   # JWT anon
